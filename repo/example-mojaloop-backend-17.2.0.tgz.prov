apiVersion: v2
appVersion: 'nginx: 4.12.0; mysql: 14.0.3; kafka: 31.5.0; mongodb: 18.5.0; redis:
  25.3.0'
dependencies:
- - alias: kafka
  condition: kafka.enabled
  name: kafka
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - kafka
  version: 31.5.0
- - alias: mysql
  condition: mysql.enabled
  name: mysql
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mysql
  - centralledger
  - account-lookup
  version: 14.0.3
- - alias: cl-mongodb
  condition: cl-mongodb.enabled
  name: mongodb
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mongodb
  - centralledger
  version: 18.5.0
- - alias: cep-mongodb
  condition: cep-mongodb.enabled
  name: mongodb
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mongodb
  - centralledger
  version: 18.5.0
- - alias: ttk-mongodb
  condition: ttk-mongodb.enabled
  name: mongodb
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mongodb
  - centralledger
  version: 18.5.0
- - alias: ttksims-redis
  condition: ttksims-redis.enabled
  name: redis
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - redis
  - sdk
  - bulk
  - ttksims
  version: 25.3.0
- - alias: auth-svc-redis
  condition: auth-svc-redis.enabled
  name: redis
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - redis
  - thirdparty
  version: 25.3.0
- - alias: proxy-cache-redis
  condition: proxy-cache-redis.enabled
  name: redis-cluster
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - redis
  - proxy
  version: 10.2.8
- - alias: proxy-cache-redis-standalone
  condition: proxy-cache-redis-standalone.enabled
  name: redis
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - redis
  - proxy
  version: 20.11.4
