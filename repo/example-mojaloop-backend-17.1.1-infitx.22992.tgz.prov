apiVersion: v2
appVersion: 'nginx: 4.12.0; mysql: 14.0.0; kafka: 31.5.0; mongodb: 16.5.36; redis:
  21.2.14'
dependencies:
- - alias: kafka
  condition: kafka.enabled
  name: kafka
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - kafka
  version: 31.5.0
- - alias: mysql
  condition: mysql.enabled
  name: mysql
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mysql
  - centralledger
  - account-lookup
  version: 14.0.0
- - alias: cl-mongodb
  condition: cl-mongodb.enabled
  name: mongodb
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mongodb
  - centralledger
  version: 16.5.36
- - alias: cep-mongodb
  condition: cep-mongodb.enabled
  name: mongodb
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mongodb
  - centralledger
  version: 16.5.36
- - alias: ttk-mongodb
  condition: ttk-mongodb.enabled
  name: mongodb
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mongodb
  - centralledger
  version: 16.5.36
- - alias: ttksims-redis
  condition: ttksims-redis.enabled
  name: redis
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - redis
  - sdk
  - bulk
  - ttksims
  version: 21.2.14
- - alias: auth-svc-redis
  condition: auth-svc-redis.enabled
  name: redis
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - redis
  - thirdparty
  version: 21.2.14
- - alias: proxy-cache-redis
  condition: proxy-cache-redis.enabled
  name: redis-cluster
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - redis
  - proxy
  version: 10.2.8
- - alias: proxy-cache-redis-standalone
  condition: proxy-cache-redis-standalone.enabled
  name: redis
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
