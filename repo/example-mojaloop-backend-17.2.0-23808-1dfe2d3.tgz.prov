- - alias: kafka
  condition: kafka.enabled
  name: kafka
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - kafka
  version: 31.5.0
- - alias: mysql
  condition: mysql.enabled
  name: mysql
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mysql
  - centralledger
  - account-lookup
  version: 14.0.3
