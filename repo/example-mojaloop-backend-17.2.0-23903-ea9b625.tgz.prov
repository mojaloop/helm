  condition: cl-mongodb.enabled
  name: mongodb
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mongodb
  - centralledger
  version: 18.6.1
- - alias: cep-mongodb
  condition: cep-mongodb.enabled
  name: mongodb
  repository: https://charts.bitnami.com/bitnami
  tags:
  - mojaloop
  - dependency
  - backend
  - mongodb
  - centralledger
  version: 18.6.1
- - alias: ttk-mongodb
  condition: ttk-mongodb.enabled
