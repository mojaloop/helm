<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ if contains "/self-service/recovery/api" .RequestURL }}Set up your account{{ else }}Reset your password{{ end }}</title>
</head>
<body style="margin:0;padding:0;background-color:#f1f4f6;-webkit-text-size-adjust:100%;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f1f4f6;padding:32px 0;">
    <tr>
      <td align="center">
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background-color:#ffffff;border-radius:8px;overflow:hidden;box-shadow:0 1px 4px rgba(16,42,56,0.12);">
          <tr>
            <td style="background-color:#12303e;padding:28px 40px;">
              <span style="font-family:Arial,Helvetica,sans-serif;font-size:20px;font-weight:bold;color:#ffffff;letter-spacing:0.5px;">mojaloop</span>
              <span style="font-family:Arial,Helvetica,sans-serif;font-size:13px;color:#9fb6c0;letter-spacing:1px;text-transform:uppercase;padding-left:10px;">Hub</span>
            </td>
          </tr>
          <tr>
            <td style="padding:40px 40px 8px 40px;">
              <h1 style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:22px;line-height:30px;color:#12303e;">{{ if contains "/self-service/recovery/api" .RequestURL }}You have been invited{{ else }}Reset your password{{ end }}</h1>
            </td>
          </tr>
          <tr>
            <td style="padding:16px 40px 0 40px;">
              <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:24px;color:#3c5560;">
                {{ if contains "/self-service/recovery/api" .RequestURL }}
                A Mojaloop Hub account has been created for you.
                Click the button below to set your password and complete your profile.
                {{ else }}
                We received a request to reset the password of your Mojaloop Hub account.
                Click the button below to choose a new one.
                {{ end }}
              </p>
            </td>
          </tr>
          <tr>
            <td align="center" style="padding:32px 40px;">
              <a href="{{ .RecoveryURL }}" style="display:inline-block;background-color:#00a3ad;color:#ffffff;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:bold;line-height:20px;text-decoration:none;padding:14px 36px;border-radius:6px;">{{ if contains "/self-service/recovery/api" .RequestURL }}Set up your account{{ else }}Reset password{{ end }}</a>
            </td>
          </tr>
          <tr>
            <td style="padding:0 40px;">
              <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:20px;color:#6b8694;">
                If the button does not work, copy and paste this link into your browser:
              </p>
              <p style="margin:8px 0 0 0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:20px;word-break:break-all;">
                <a href="{{ .RecoveryURL }}" style="color:#00a3ad;text-decoration:underline;">{{ .RecoveryURL }}</a>
              </p>
            </td>
          </tr>
          <tr>
            <td style="padding:28px 40px 36px 40px;">
              <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:20px;color:#6b8694;">
                This link expires in {{ if ge .ExpiresInMinutes 1440 }}{{ div .ExpiresInMinutes 1440 }} days{{ else if ge .ExpiresInMinutes 60 }}{{ div .ExpiresInMinutes 60 }} hours{{ else }}{{ .ExpiresInMinutes }} minutes{{ end }}.
                If you did not expect this email, you can safely ignore it.
              </p>
            </td>
          </tr>
        </table>
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;">
          <tr>
            <td align="center" style="padding:20px 40px;">
              <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:12px;line-height:18px;color:#8aa0ab;">
                Mojaloop Hub
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
